		"@types/semver": "^7.7.1",
		"@vitejs/plugin-react": "^6.0.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^1.0.0-beta.16-ea816b6",
		"lefthook": "^2.1.4",
		"lightningcss": "^1.32.0",
